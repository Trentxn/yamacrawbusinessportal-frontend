# =============================================================================
# Yamacraw Business Portal - Production Environment Variables
# Copy this file to .env.prod and fill in real values
# NEVER commit .env.prod to git
# =============================================================================

# --- App ---
DEBUG=false

# --- Database ---
POSTGRES_USER=yamacraw
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=yamacraw_portal
DATABASE_URL=postgresql://yamacraw:CHANGE_ME_STRONG_PASSWORD_HERE@postgres:5432/yamacraw_portal

# --- JWT ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_64_CHAR_SECRET

# --- CORS ---
CORS_ORIGINS=https://yamacrawbusinessportal.com,https://www.yamacrawbusinessportal.com

# --- Email (Resend) ---
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
EMAIL_FROM=Yamacraw Business Portal <info@yamacrawbusinessportal.com>

# --- Cloudflare Turnstile CAPTCHA ---
# Get keys from: https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=0x_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- Uploads ---
UPLOAD_DIR=/var/uploads
