# Copy this file to `.env` and fill in your values.
# `.env` is gitignored.

# ── Narrator (ElevenLabs) ───────────────────────────────────────────────────
# Get a free API key at https://elevenlabs.io (no credit card, ~10k chars/month).
ELEVENLABS_API_KEY=

# Optional — defaults to Rachel (21m00Tcm4TlvDq8ikWAM) if not set.
# Find voice IDs at https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Force which TTS provider to use. Leave unset to auto-detect
# (elevenlabs if ELEVENLABS_API_KEY is set, otherwise edge).
# Values: elevenlabs | edge
# TTS_PROVIDER=elevenlabs
